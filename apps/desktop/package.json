{
    "name": "@burndata/desktop",
    "version": "1.0.1",
    "private": true,
    "description": "BurnData Desktop Application - Electron + React",
    "main": "dist-electron/main.js",
    "scripts": {
        "dev": "vite",
        "build": "tsc && vite build && electron-builder",
        "build:vite": "vite build",
        "preview": "vite preview",
        "lint": "eslint . --ext .ts,.tsx --max-warnings 0",
        "typecheck": "tsc --noEmit",
        "electron:dev": "electron .",
        "clean": "rimraf dist dist-electron"
    },
    "dependencies": {
        "axios": "^1.13.4",
        "date-fns": "^3.6.0",
        "electron-store": "^8.2.0",
        "framer-motion": "^10.18.0",
        "jszip": "^3.10.1",
        "lucide-react": "^0.303.0",
        "react": "^18.3.1",
        "react-dom": "^18.3.1",
        "react-router-dom": "^6.30.3",
        "zod": "^3.23.8",
        "zustand": "^4.5.7"
    },
    "devDependencies": {
        "@types/react": "^18.3.28",
        "@types/react-dom": "^18.3.7",
        "@vitejs/plugin-react": "^4.7.0",
        "autoprefixer": "^10.4.24",
        "electron": "^28.3.3",
        "electron-builder": "^24.13.3",
        "postcss": "^8.5.6",
        "rimraf": "^5.0.10",
        "tailwindcss": "^3.4.19",
        "typescript": "^5.9.3",
        "vite": "^5.4.21",
        "vite-plugin-electron": "^0.15.6",
        "vite-plugin-electron-renderer": "^0.14.6"
    },
    "build": {
        "appId": "com.burndata.app",
        "productName": "BurnData",
        "copyright": "Copyright © 2026 BurnData",
        "directories": {
            "output": "release",
            "buildResources": "build"
        },
        "files": [
            "dist/**/*",
            "dist-electron/**/*"
        ],
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "installerIcon": "build/icon.ico",
            "uninstallerIcon": "build/icon.ico",
            "installerHeaderIcon": "build/icon.ico",
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "BurnData"
        },
        "mac": {
            "target": "dmg",
            "category": "public.app-category.utilities"
        },
        "linux": {
            "target": "AppImage",
            "category": "Utility"
        }
    }
}